# Copie este arquivo para um novo chamado ".env" (sem o ".exemplo")
# e cole sua chave da OpenAI no lugar de XXXX.
OPENAI_API_KEY=sk-XXXX

# --- Acesso ao sistema (tela de login) ---
APP_USUARIO=fabio
APP_SENHA=troque_esta_senha
# Token que protege a API (qualquer texto aleatório longo)
APP_TOKEN=troque_por_um_texto_aleatorio_longo

# --- Supabase (opcional; preencha para salvar na internet) ---
# Sem estas duas linhas, o app salva em arquivos locais.
SUPABASE_URL=
SUPABASE_KEY=
